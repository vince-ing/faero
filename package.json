{
  "name": "faero-aquarium",
  "version": "1.0.0",
  "description": "Frutiger Aero transparent aquarium overlay",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "package": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.faero.aquarium",
    "productName": "Faero Aquarium",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "keywords": [
    "electron",
    "aquarium",
    "overlay",
    "frutiger-aero",
    "webgl"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "koffi": "^2.15.2"
  }
}
